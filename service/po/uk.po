#: service/lib/agama/storage/config_checkers/search.rb:256
#, perl-brace-format
msgid ""
"The device '%{member_name}' cannot be formatted because it is a physical "
"volume of the reused LVM volume group '%{reused_name}'"
msgstr ""
"Об'єкт «%{member_name}» неможливо відформатувати, оскільки це фізичний том "
"групи томів LVM, що використовується повторно, «%{reused_name}»"

#. Issue if the device member is partitioned.
#.
#. @param member_config [#search]
#. @return [Issue, nil]
#: service/lib/agama/storage/config_checkers/search.rb:286
#, perl-brace-format
msgid ""
"The device '%{member_name}' cannot be partitioned because it is part of the "
"reused MD RAID '%{reused_name}'"
msgstr ""
"Пристрій «%{member_name}» не можна розділити на розділи, оскільки він "
"входить до складу повторно використовуваного масиву MD RAID «%{reused_name}»"

#. TRANSLATORS: %{member_name} and %{reused_name} are replaced by device names (e.g.,
#. "/dev/vda", "/dev/md0").
#: service/lib/agama/storage/config_checkers/search.rb:296
#, perl-brace-format
msgid ""
"The device '%{member_name}' cannot be partitioned because it is a physical "
