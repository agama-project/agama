msgstr "Úprava konfigurácie iSCSI"

#. Step to configure the file-system snapshots
#: service/lib/agama/storage/finisher.rb:200
msgid "Configuring file systems snapshots"
msgstr "Konfigurácia snímok súborových systémov"

#. Returns an issue if there is no candidate device for installation
#.
#. @return [Issue, nil]
#: service/lib/agama/storage/manager.rb:308
msgid "There is no suitable device for installation"
msgstr "Nie je k dispozícii žiadne vhodné zariadenie na inštaláciu"

#. Issue representing the proposal is not valid.
#.
#. @return [Issue]
#: service/lib/agama/storage/proposal.rb:351
msgid "Cannot calculate a valid storage setup with the current configuration"
msgstr ""
"Nie je možné vypočítať platné nastavenie úložiska pri aktuálnej konfigurácii"

#. Issue to communicate a generic Y2Storage error.
#.
#. @return [Issue]
#: service/lib/agama/storage/proposal.rb:361
msgid "A problem occurred while calculating the storage setup"
msgstr "Vyskytol sa problém pri výpočte nastavenia úložiska"

#. Step to copy the installation logs
#: service/lib/agama/storage/umounter.rb:112
msgid "Copying logs"
msgstr "Kopírovanie záznamov"

#. Step to unmount the target file-systems
#: service/lib/agama/storage/umounter.rb:153
msgid "Unmounting storage devices"
msgstr "Odpojenie úložných zariadení"

#. Activates the controller if it is not active yet.
#.
#. @note: If "allow_lun_scan" is active, then all its LUNs are automatically activated.
#.
#. @param controller [Controller]
#. @return [Boolean] Whether the controller was activated.
#: service/lib/agama/storage/zfcp/manager.rb:206
#, c-format
msgid "The zFCP controller %s cannot be activated"
msgstr "Radič zFCP %s nie je možné aktivovať"

#. Activates a device if it is not active yet.
#.
#. @param device [Device]
#. @return [Boolean] Whether the device was activated.
#: service/lib/agama/storage/zfcp/manager.rb:239
#, c-format
msgid "The zFCP device %s cannot be activated"
msgstr "Zariadenie zFCP %s nie je možné aktivovať"

#. Deactivates a device if it is active.
#.
#. @note: If "allow_lun_scan" is active, then the disk cannot be deactivated.
#.
#. @param device [Device]
#. @return [Boolean] Whether the device was deactivated.
#: service/lib/agama/storage/zfcp/manager.rb:277
#, c-format
msgid "The zFCP device %s cannot be deactivated"
msgstr "Zariadenie zFCP %s nie je možné deaktivovať"

#. Issue if the controller is missing.
#.
#. @param channel [String]
#. @return [Issue, nil]
#: service/lib/agama/storage/zfcp/manager.rb:307
#, c-format
msgid "Unknown zFCP controller %s"
msgstr "Neznámy radič zFCP %s"

#. Issue if the device is missing.
#.
#. @param device_config [Configs::Device]
#. @return [Issue, nil]
#: service/lib/agama/storage/zfcp/manager.rb:326
#, c-format
msgid "Unknown zFCP LUN %s"
msgstr "Neznáme zFCP LUN %s"

