msgstr "Un problème est survenu lors du calcul de la configuration du stockage"

#. Step to copy the installation logs
#: service/lib/agama/storage/umounter.rb:112
msgid "Copying logs"
msgstr "Journaux en cours de copie"

#. Step to unmount the target file-systems
#: service/lib/agama/storage/umounter.rb:153
msgid "Unmounting storage devices"
msgstr "Démontage des périphériques de stockage"

#. Activates the controller if it is not active yet.
#.
#. @note: If "allow_lun_scan" is active, then all its LUNs are automatically activated.
#.
#. @param controller [Controller]
#. @return [Boolean] Whether the controller was activated.
#: service/lib/agama/storage/zfcp/manager.rb:206
#, c-format
msgid "The zFCP controller %s cannot be activated"
msgstr "Le contrôleur zFCP %s ne peut pas être activé"

#. Activates a device if it is not active yet.
#.
#. @param device [Device]
#. @return [Boolean] Whether the device was activated.
#: service/lib/agama/storage/zfcp/manager.rb:239
#, c-format
msgid "The zFCP device %s cannot be activated"
msgstr "L'appareil zFCP %s ne peut pas être activé"

#. Deactivates a device if it is active.
#.
#. @note: If "allow_lun_scan" is active, then the disk cannot be deactivated.
#.
#. @param device [Device]
#. @return [Boolean] Whether the device was deactivated.
#: service/lib/agama/storage/zfcp/manager.rb:277
#, c-format
msgid "The zFCP device %s cannot be deactivated"
msgstr "L'appareil zFCP %s ne peut pas être désactivé"

#. Issue if the controller is missing.
