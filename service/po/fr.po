msgstr "Éléments non pris en charge trouvés dans le profil AutoYaST : %{keys}."

#. Implementation for the API method #Probe.
#: service/lib/agama/dbus/storage/dasd.rb:68
msgid "Probing DASD devices"
msgstr "Sondage des appareils DASD"

#. The configuration could take long time  (e.g., formatting devices). It is important to
#. not block the service in order to make possible to attend other requests.
#: service/lib/agama/dbus/storage/dasd.rb:94
msgid "Configuring DASD"
msgstr "Configuration de DASD"

#. Do not configure if there is nothing to change.
