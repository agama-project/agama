#. Issue if the volume group name is missing.
#.
#. @return [Issue, nil]
#: service/lib/agama/storage/config_checkers/volume_group.rb:80
msgid "There is a volume group without name"
msgstr "Ada grup volume tanpa nama"

#. TRANSLATORS: %s is the replaced by a device alias (e.g., "pv1").
#: service/lib/agama/storage/config_checkers/volume_group.rb:112
#, c-format
msgid "There is no LVM physical volume with alias '%s'"
msgstr "Tidak ada volume fisik LVM dengan alias '%s'"

#. TRANSLATORS: %s is the replaced by a device alias (e.g., "pv1").
#: service/lib/agama/storage/config_checkers/volume_group.rb:139
#, c-format
