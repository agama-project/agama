#. Text of the reason preventing to shrink because there is no content.
#.
#. @return [String, nil] nil if there is content or there is any other reasons.
#: service/lib/agama/storage/device_shrinking.rb:151
msgid ""
"Neither a file system nor a storage system was detected on the device. In "
"case the device does contain a file system or a storage system that is not "
"supported, resizing will most likely cause data loss."
msgstr ""
"Tiedostojärjestelmää tai tallennusjärjestelmää ei havaittu laitteella. "
"Mikäli laitteella on kuitenkin tiedosto- tai tallennusjärjestelmä jota ei "
"tueta, laitteen koon muuttaminen aiheuttaa luultavasti tietojen häviämistä."

#. Text of the reason preventing to shrink because there is no valid minimum size.
#.
#. @return [String, nil] nil if there is a minimum size or there is any other reasons.
#: service/lib/agama/storage/device_shrinking.rb:162
msgid "Shrinking is not supported by this device"
msgstr "Tämä laite ei tue koon pienentämistä"

#. Copy /etc/nvme/host* to keep NVMe working after installation, bsc#1238038
#: service/lib/agama/storage/finisher.rb:126
msgid "Copying important installation files to the target system"
msgstr "Kopioidaan tärkeitä asennustiedostoja kohdejärjestelmään"

#. Step to write the bootloader configuration
#: service/lib/agama/storage/finisher.rb:161
msgid "Installing bootloader"
msgstr "Asennetaan käynnistyslatainta"

#. Step to finish the Y2Storage configuration
#: service/lib/agama/storage/finisher.rb:178
msgid "Adjusting storage configuration"
msgstr "Tallennustilan asetusten muuttaminen"

#. Step to finish the iSCSI configuration
#: service/lib/agama/storage/finisher.rb:189
msgid "Adjusting iSCSI configuration"
msgstr "Määritetään iSCSI-asetuksia"

#. Step to configure the file-system snapshots
#: service/lib/agama/storage/finisher.rb:200
msgid "Configuring file systems snapshots"
msgstr "Tehdään tiedostojärjestelmien tilannevedosten asetuksia"

#. Returns an issue if there is no candidate device for installation
#.
#. @return [Issue, nil]
#: service/lib/agama/storage/manager.rb:251
msgid "There is no suitable device for installation"
msgstr "Asennukselle ei ole sopivaa laitetta"

#. Issue representing the proposal is not valid.
#.
#. @return [Issue]
#: service/lib/agama/storage/proposal.rb:305
msgid "Cannot calculate a valid storage setup with the current configuration"
msgstr ""
"Nykyisillä asetuksilla ei voi laskea kelvollista tallennustilamääritystä"

#. Issue to communicate a generic Y2Storage error.
#.
#. @return [Issue]
#: service/lib/agama/storage/proposal.rb:315
#, fuzzy
msgid "A problem occurred while calculating the storage setup"
msgstr "Tallennustila-asetusten laskemisessa tapahtui ongelma"

#. Step to copy the installation logs
#: service/lib/agama/storage/umounter.rb:112
msgid "Copying logs"
msgstr "Kopioidaan lokeja"

#. Step to unmount the target file-systems
#: service/lib/agama/storage/umounter.rb:153
msgid "Unmounting storage devices"
msgstr "Irrotetaan tallennuslaitteita"

#. Activates the controller if it is not active yet.
#.
#. @note: If "allow_lun_scan" is active, then all its LUNs are automatically activated.
#.
#. @param controller [Controller]
#. @return [Boolean] Whether the controller was activated.
#: service/lib/agama/storage/zfcp/manager.rb:206
#, c-format
msgid "The zFCP controller %s cannot be activated"
msgstr "zFCP-ohjainta %s ei voi aktivoida"

#. Activates a device if it is not active yet.
#.
#. @param device [Device]
#. @return [Boolean] Whether the device was activated.
#: service/lib/agama/storage/zfcp/manager.rb:239
#, c-format
msgid "The zFCP device %s cannot be activated"
msgstr "zFCP-laitetta %s ei voi aktivoida"

#. Deactivates a device if it is active.
#.
#. @note: If "allow_lun_scan" is active, then the disk cannot be deactivated.
#.
#. @param device [Device]
#. @return [Boolean] Whether the device was deactivated.
#: service/lib/agama/storage/zfcp/manager.rb:277
#, c-format
msgid "The zFCP device %s cannot be deactivated"
msgstr "zFCP-laitetta %s ei voi deaktivoida"

#. Issue if the controller is missing.
#.
#. @param channel [String]
#. @return [Issue, nil]
#: service/lib/agama/storage/zfcp/manager.rb:307
#, c-format
msgid "Unknown zFCP controller %s"
msgstr "Tuntematon zFCP-ohjain %s"

#. Issue if the device is missing.
#.
#. @param device_config [Configs::Device]
#. @return [Issue, nil]
#: service/lib/agama/storage/zfcp/manager.rb:326
#, c-format
msgid "Unknown zFCP LUN %s"
msgstr "Tuntematon zFCP LUN %s"

