[Unit]
Description=Agama Installer Service
After=network-online.target

[Service]
Type=forking
ExecStart=/usr/bin/agamactl --daemon
# for testing temporarily change the libzypp default
Environment=ZYPP_SINGLE_RPMTRANS=1
EnvironmentFile=-/run/agama/environment.conf
PIDFile=/run/agama/bus.pid
User=root
TimeoutStopSec=5

[Install]
WantedBy=multi-user.target
